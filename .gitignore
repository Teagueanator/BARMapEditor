# Rust
/target/
**/target/
**/*.rs.bk
Cargo.lock.bak

# IDE / editor
/.vscode/
/.idea/
*.swp
*.swo
.DS_Store

# Local Claude settings (user-specific permissions)
/.claude/settings.local.json

# Bundled sidecar binaries (large, downloaded by build script)
/tools/pymapconv/
/tools/compressonator/
/tools/textures/
/tools/textures-cache/
/tools/feature-decals/

# Test/scratch outputs
/scratch/
/out/
*.sd7
*.sdz
*.smt
*.smf

# Generated fixtures — regen with `cargo run -p barme-core --example gen-fixture`
# (see docs/DECISIONS.md ADR-007). README.md stays tracked.
/assets/fixtures/*.png
/assets/fixtures/*.tga

# Development log (personal working notes; never tracked)
/devlog/

# OS
Thumbs.db
